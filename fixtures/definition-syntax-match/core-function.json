{
    "a( b* )": {
        "valid": [
            "a()",
            "A()",
            "a(b)",
            "a( b b b )"
        ],
        "invalid": [
            "",
            "a",
            "A",
            "a(",
            "a ()",
            "a (b)",
            "a(x)",
            "a(())",
            "a() foo",
            "a() a()"
        ]
    },
    "a( b || c )": {
        "skip": true,
        "valid": [
            "a(b)",
            "a(c)",
            "a(b c)",
            "a(c b)"
        ],
        "invalid": [
            "",
            "a()",
            "c ) a( b"
        ]
    },
    "a( [ b( ) ] )": {
        "valid": [
            "a(b())"
        ],
        "invalid": [
            "",
            "a()",
            "a(b()",
            "a(c())"
        ]
    },
    "a( [ b || c( d ) ]# )": {
        "valid": [
            "a(b c(d))",
            "a(b c(d), b c(d))"
        ],
        "invalid": [
            "",
            "a(b c)"
        ]
    }
}
